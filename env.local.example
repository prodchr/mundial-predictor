'use client';

import { useEffect, useMemo, useState } from 'react';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY!
);

const INVITE = 'mundial2026hermanos';

type Player = { id:string; name:string; player_code:string; is_admin:boolean };
type Match = { id:number; match_no:number; match_day:string; group_name:string|null; home_team:string; away_team:string; home_score:number|null; away_score:number|null; kickoff_at:string|null; is_locked:boolean|null };
type Prediction = { id:string; player_id:string; match_id:number; pred_home:number|null; pred_away:number|null };

function points(m: Match, p?: Prediction) {
  if (!p || m.home_score === null || m.away_score === null || p.pred_home === null || p.pred_away === null) return 0;
  if (m.home_score === p.pred_home && m.away_score === p.pred_away) return 3;
  const r = m.home_score > m.away_score ? 'H' : m.home_score < m.away_score ? 'A' : 'D';
  const g = p.pred_home > p.pred_away ? 'H' : p.pred_home < p.pred_away ? 'A' : 'D';
  return r === g ? 1 : 0;
}
function locked(m: Match) {
  if (m.is_locked) return true;
  if (!m.kickoff_at) return false;
  return new Date() >= new Date(m.kickoff_at);
}
function standings(matches: Match[]) {
  const t: Record<string, any[]> = {};
  matches.forEach(m => {
    const g = m.group_name || 'Other';
    t[g] ||= [];
    [m.home_team, m.away_team].forEach(team => {
      if (!t[g].find(x => x.team === team)) t[g].push({team,P:0,GF:0,GA:0,GD:0,Pts:0});
    });
  });
  matches.forEach(m => {
    if (m.home_score === null || m.away_score === null) return;
    const g = m.group_name || 'Other', h = t[g].find(x=>x.team===m.home_team), a = t[g].find(x=>x.team===m.away_team);
    h.P++; a.P++; h.GF+=m.home_score; h.GA+=m.away_score; a.GF+=m.away_score; a.GA+=m.home_score;
    if (m.home_score > m.away_score) h.Pts += 3; else if (m.home_score < m.away_score) a.Pts += 3; else { h.Pts++; a.Pts++; }
    h.GD=h.GF-h.GA; a.GD=a.GF-a.GA;
  });
  Object.keys(t).forEach(g => t[g].sort((a,b)=>b.Pts-a.Pts || b.GD-a.GD || b.GF-a.GF));
  return t;
}

export default function Page() {
  const [me,setMe]=useState<Player|null>(null);
  const [players,setPlayers]=useState<Player[]>([]);
  const [matches,setMatches]=useState<Match[]>([]);
  const [preds,setPreds]=useState<Prediction[]>([]);
  const [tab,setTab]=useState('dashboard');
  const [code,setCode]=useState('');
  const [name,setName]=useState('');
  const [invite,setInvite]=useState('');
  const [msg,setMsg]=useState('');

  async function load() {
    const [m,p,pr]=await Promise.all([
      supabase.from('matches').select('*').order('match_no'),
      supabase.from('players').select('*').order('created_at'),
      supabase.from('predictions').select('*')
    ]);
    setMatches(m.data||[]); setPlayers(p.data||[]); setPreds(pr.data||[]);
  }
  useEffect(()=>{load()},[]);
  const pred=(pid:string,mid:number)=>preds.find(p=>p.player_id===pid&&p.match_id===mid);

  async function login(){
    setMsg('');
    const {data}=await supabase.from('players').select('*').eq('player_code',code.trim()).single();
    if(!data) return setMsg('Λάθος κωδικός');
    setMe(data);
  }
  async function join(){
    setMsg('');
    if(invite.trim()!==INVITE) return setMsg('Λάθος invite code');
    if(!name.trim()) return setMsg('Βάλε όνομα');
    const player_code = name.toUpperCase().replace(/[^A-Z0-9]/g,'').slice(0,10) + Math.floor(1000+Math.random()*9000);
    const {data,error}=await supabase.from('players').insert({name,player_code,is_admin:false}).select('*').single();
    if(error) return setMsg(error.message);
    setMe(data); setMsg('Ο κωδικός σου: '+player_code); await load();
  }
  async function savePrediction(m:Match, f:'pred_home'|'pred_away', v:string){
    if(!me || me.is_admin || locked(m) || (v!=='' && !/^\d{0,2}$/.test(v))) return;
    const existing=pred(me.id,m.id);
    if(existing) await supabase.from('predictions').update({[f]:v===''?null:Number(v)}).eq('id',existing.id);
    else await supabase.from('predictions').insert({player_id:me.id,match_id:m.id,[f]:v===''?null:Number(v)});
    await load();
  }
  async function saveScore(m:Match, f:'home_score'|'away_score', v:string){
    if(!me?.is_admin || (v!=='' && !/^\d{0,2}$/.test(v))) return;
    await supabase.from('matches').update({[f]:v===''?null:Number(v)}).eq('id',m.id);
    await load();
  }

  const board=useMemo(()=>players.filter(p=>!p.is_admin).map(p=>({
    ...p, pts: matches.reduce((s,m)=>s+points(m,pred(p.id,m.id)),0)
  })).sort((a,b)=>b.pts-a.pts),[players,matches,preds]);
  const groups=useMemo(()=>standings(matches),[matches]);

  const style:any={bg:{background:'#020617',color:'white',minHeight:'100vh',padding:24,fontFamily:'Arial'},card:{background:'rgba(255,255,255,.08)',border:'1px solid rgba(255,255,255,.12)',borderRadius:20,padding:16,marginTop:16},btn:{background:'#fbbf24',border:0,borderRadius:12,padding:'10px 14px',fontWeight:700,marginRight:8},input:{padding:10,borderRadius:10,border:'1px solid #334155',background:'#0f172a',color:'white',margin:4},table:{width:'100%',borderCollapse:'collapse'},td:{borderTop:'1px solid rgba(255,255,255,.12)',padding:10}};

  if(!me) return <main style={style.bg}><div style={{maxWidth:420,margin:'60px auto',...style.card}}>
    <h1 style={{color:'#fbbf24'}}>Mundial Predictor</h1>
    <input style={style.input} placeholder="Προσωπικός κωδικός" value={code} onChange={e=>setCode(e.target.value)}/><button style={style.btn} onClick={login}>Login</button>
    <hr style={{borderColor:'#334155'}}/>
    <input style={style.input} placeholder="Όνομα" value={name} onChange={e=>setName(e.target.value)}/>
    <input style={style.input} placeholder="Invite code" value={invite} onChange={e=>setInvite(e.target.value)}/>
    <button style={style.btn} onClick={join}>Join</button>
    <p>{msg}</p>
  </div></main>;

  return <main style={style.bg}>
    <h1 style={{color:'#fbbf24'}}>Mundial Predictor</h1><p>Συνδεδεμένος ως <b>{me.name}</b> · {me.player_code}</p>
    {['dashboard','predictions','leaderboard','groups'].map(t=><button key={t} style={style.btn} onClick={()=>setTab(t)}>{t}</button>)}
    {me.is_admin && <button style={style.btn} onClick={()=>setTab('admin')}>admin</button>}
    <button style={style.btn} onClick={load}>refresh</button>

    {tab==='dashboard' && <div style={style.card}><h2>Top 3</h2>{board.slice(0,3).map((p,i)=><h3 key={p.id}>{['🥇','🥈','🥉'][i]} {p.name}: {p.pts} pts</h3>)}</div>}

    {tab==='predictions' && <div style={style.card}><h2>Οι προβλέψεις μου</h2><table style={style.table}><tbody>{matches.map(m=>{const p=pred(me.id,m.id); return <tr key={m.id}><td style={style.td}>{m.match_day}</td><td style={style.td}>{m.group_name}</td><td style={style.td}><b>{m.home_team} vs {m.away_team}</b></td><td style={style.td}><input disabled={locked(m)} style={style.input} value={p?.pred_home??''} onChange={e=>savePrediction(m,'pred_home',e.target.value)}/> - <input disabled={locked(m)} style={style.input} value={p?.pred_away??''} onChange={e=>savePrediction(m,'pred_away',e.target.value)}/></td><td style={style.td}>{locked(m)?'🔒 locked':'🟢 open'}</td><td style={style.td}>{points(m,p)} pts</td></tr>})}</tbody></table></div>}

    {tab==='leaderboard' && <div style={style.card}><h2>Κατάταξη παικτών</h2>{board.map((p,i)=><p key={p.id}><b>{i+1}. {p.name}</b> — {p.pts} pts</p>)}</div>}

    {tab==='groups' && <div>{Object.entries(groups).map(([g,rows]:any)=><div key={g} style={style.card}><h2>Group {g}</h2>{rows.map((r:any)=><p key={r.team}><b>{r.team}</b> — Pts {r.Pts}, GD {r.GD}</p>)}</div>)}</div>}

    {tab==='admin' && me.is_admin && <div style={style.card}><h2>Admin αποτελέσματα</h2><table style={style.table}><tbody>{matches.map(m=><tr key={m.id}><td style={style.td}>{m.match_day}</td><td style={style.td}>{m.home_team} vs {m.away_team}</td><td style={style.td}><input style={style.input} value={m.home_score??''} onChange={e=>saveScore(m,'home_score',e.target.value)}/> - <input style={style.input} value={m.away_score??''} onChange={e=>saveScore(m,'away_score',e.target.value)}/></td></tr>)}</tbody></table></div>}
  </main>
}
